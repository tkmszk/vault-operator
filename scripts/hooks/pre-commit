#!/usr/bin/env bash
# Obsilo pre-commit hook: runs consistency-check Mode A with auto-fix.
# Non-fixable findings prompt the user to launch the interactive
# fix loop in Claude Code (Mode C). Bypass with --no-verify.
#
# Install with: scripts/install-hooks.sh

set -euo pipefail
ROOT=$(git rev-parse --show-toplevel)
SCRIPT="$ROOT/scripts/consistency-check.py"

if [ ! -x "$SCRIPT" ]; then
    echo "[pre-commit] consistency-check.py not found or not executable -- skipping"
    exit 0
fi

if ! python3 "$SCRIPT" --fix; then
    # Findings remain. Offer the interactive fix loop.
    echo
    echo "Commit blocked by consistency-check findings."
    echo

    # Don't prompt in non-interactive contexts (CI, IDE pre-commit silent mode).
    if [ ! -t 0 ] || [ ! -t 1 ]; then
        echo "Non-interactive shell -- run manually:"
        echo "    claude /consistency-check --fix-interactive"
        echo "Or bypass: git commit --no-verify"
        exit 1
    fi

    # 3C: ask before launching Claude.
    read -r -p "Launch interactive fix loop in Claude Code now? [y/N] " answer
    answer=${answer:-N}
    case "$answer" in
        [yY]|[yY][eE][sS])
            if command -v claude >/dev/null 2>&1; then
                echo "Launching: claude /consistency-check --fix-interactive"
                exec claude /consistency-check --fix-interactive
            else
                echo "claude binary not found in PATH."
                echo "Install Claude Code or run the loop manually:"
                echo "    claude /consistency-check --fix-interactive"
                exit 1
            fi
            ;;
        *)
            echo
            echo "Findings file: .git/consistency-check.last-run.json"
            echo "Resume later: claude /consistency-check --fix-interactive"
            echo "Bypass commit-check: git commit --no-verify"
            exit 1
            ;;
    esac
fi

exit 0
